# =============================================================================
# NexusAI 环境变量模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# ---- 运行环境 ----
NEXUS_ENV=development
DEBUG=false
APP_NAME=nexus-python
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
JSON_LOGS=false

# ---- LLM 大语言模型 ----
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-pro

# ---- Embedding 向量化 ----
# 提供商: openai 或 bge
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_API_KEY=
# 维度: OpenAI 默认 1536, BGE 默认 1024
EMBEDDING_DIMENSIONS=1536

# ---- MySQL 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nexusai
DB_USERNAME=root
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ---- Redis 缓存 ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- Milvus 向量数据库 ----
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=nexus_content_vectors
# 语义去重阈值: 相似度 > 此值视为重复
MILVUS_DEDUP_THRESHOLD=0.92
# 关联推荐阈值: 相似度在此区间建立关联
MILVUS_RELATE_THRESHOLD=0.75
MILVUS_TOP_K=5

# ---- RocketMQ 消息队列 ----
ROCKETMQ_NAMESERVER=localhost:9876
ROCKETMQ_PRODUCER_GROUP=nexus-python-producers
ROCKETMQ_CONSUMER_GROUP=nexus-scout-consumers

# ---- Playwright 浏览器自动化 ----
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MAX_CONCURRENT_BROWSERS=3
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=30000

# ---- 外部 API 密钥 ----
# NewsAPI.org (https://newsapi.org/register)
NEWSAPI_KEY=
# Current News API
CURRENT_NEWS_API_KEY=
